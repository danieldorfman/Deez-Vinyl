{
  "name": "deez-vinyl",
  "version": "6.0.0",
  "description": "Deez Vinyl X — polished Spotify vinyl desktop player",
  "main": "src/main.js",
  "author": "Deez Vinyl",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js",
    "dist:portable": "electron-builder --win portable --config.artifactName=DeezVinyl-${version}-${arch}-Portable.${ext}"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.deezvinyl.app",
    "productName": "Deez Vinyl",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Deez Vinyl",
      "runAfterFinish": true
    },
    "artifactName": "DeezVinyl-${version}-${arch}-Setup.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  }
}
